---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileAvatar from "../components/ProfileAvatar.astro";
import { profile, skillGroups, timeline } from "../data";
---

<BaseLayout title="About | muxin.space" description="关于我、关于这个站点、关于为什么持续分享。">
  <section class="mx-auto max-w-5xl animate-fade-in-up motion-reduce:animate-none">
    <div class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
      <div>
        <p class="text-sm font-medium text-violet-600">About</p>
        <h1 class="mt-3 font-serif text-5xl tracking-tight text-zinc-900 sm:text-6xl">
          你好，我是 Muxin。
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-zinc-500 sm:text-lg">
          我是 AI 专业本科生，偏产品与工程落地的全栈开发者，也是二次元摄影师。
          这个网站是我的知识分享主站，会慢慢长成项目公开记录、内容归档中心和个人风格展示页。
        </p>

        <div class="mt-8 flex flex-wrap gap-3 text-sm text-zinc-500">
          <a href="mailto:hello@muxin.space" class="rounded-full border border-zinc-200 bg-white px-4 py-2 transition hover:border-violet-200 hover:text-violet-600">
            hello@muxin.space
          </a>
          <span class="rounded-full border border-zinc-200 bg-white px-4 py-2">
            {profile.badge}
          </span>
        </div>
      </div>

      <div class="justify-self-start lg:justify-self-end">
        <ProfileAvatar
          src={profile.avatar}
          alt={`${profile.name} 的头像`}
          sizeClass="h-44 w-44"
          badge="关于我"
        />
      </div>
    </div>
  </section>

  <section class="mx-auto mt-14 grid max-w-5xl animate-fade-in-up motion-reduce:animate-none [animation-delay:120ms] gap-6 lg:grid-cols-2">
    <article class="rounded-[2rem] border border-zinc-100 bg-white p-6 shadow-[0_1px_0_rgba(24,24,27,0.02)]">
      <p class="text-sm font-medium text-violet-600">近期轨迹</p>
      <div class="mt-5 space-y-5">
        {timeline.map((item) => (
          <div class="relative pl-5">
            <span class="absolute left-0 top-2 h-2.5 w-2.5 rounded-full bg-violet-400"></span>
            <p class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-400">{item.period}</p>
            <h3 class="mt-1 font-serif text-xl tracking-tight text-zinc-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-7 text-zinc-500">{item.description}</p>
          </div>
        ))}
      </div>
    </article>

    <article class="rounded-[2rem] border border-zinc-100 bg-white p-6 shadow-[0_1px_0_rgba(24,24,27,0.02)]">
      <p class="text-sm font-medium text-violet-600">技能</p>
      <div class="mt-5 space-y-6">
        {skillGroups.map((group) => (
          <div>
            <h3 class="font-serif text-xl tracking-tight text-zinc-900">{group.title}</h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="rounded-full border border-zinc-200 bg-zinc-50 px-3 py-1 text-sm text-zinc-600">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </article>
  </section>
</BaseLayout>
