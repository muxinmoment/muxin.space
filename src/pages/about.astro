---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileAvatar from "../components/ProfileAvatar.astro";
import { profile, projects, skillGroups, timeline } from "../data";

const skillCount = skillGroups.reduce((total, group) => total + group.items.length, 0);
---

<BaseLayout title="About | muxin.space" description="关于我、关于这个站点、关于为什么持续分享。">
  <div class="grid gap-8 lg:grid-cols-12 lg:gap-10 xl:gap-14 2xl:gap-16">
    <aside class="animate-fade-in-up motion-reduce:animate-none lg:col-span-4 xl:col-span-3 lg:sticky lg:top-24 lg:self-start">
      <div class="rounded-[2.3rem] border border-zinc-100 bg-white/90 p-7 shadow-[0_20px_60px_rgba(24,24,27,0.05)] backdrop-blur sm:p-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-violet-100 bg-violet-50/80 px-4 py-2 text-sm font-medium text-violet-700">
          <span>✦</span>
          <span>About</span>
        </div>

        <div class="mt-6">
          <ProfileAvatar
            src={profile.avatar}
            alt={`${profile.name} 的头像`}
            sizeClass="h-36 w-36 sm:h-40 sm:w-40"
            badge="关于我"
          />
        </div>

        <div class="mt-6">
          <p class="text-sm font-medium uppercase tracking-[0.28em] text-zinc-400">Identity</p>
          <h1 class="mt-3 font-serif text-4xl tracking-tight text-zinc-900">{profile.name}</h1>
          <p class="mt-4 text-sm leading-7 text-zinc-600">{profile.description}</p>
        </div>

        <div class="mt-6 flex flex-wrap gap-3 text-sm text-zinc-500">
          <a
            href="mailto:hello@muxin.space"
            class="rounded-full border border-zinc-200 bg-white px-4 py-2 transition hover:border-violet-200 hover:text-violet-600"
          >
            hello@muxin.space
          </a>
          <span class="rounded-full border border-zinc-200 bg-zinc-50 px-4 py-2">
            {profile.badge}
          </span>
        </div>

        <div class="mt-8 grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
          <article class="rounded-2xl border border-zinc-100 bg-zinc-50/80 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-zinc-400">Timeline</p>
            <p class="mt-2 font-serif text-2xl text-zinc-900">{timeline.length}</p>
            <p class="mt-1 text-xs leading-6 text-zinc-500">当前公开整理的人生与项目节点</p>
          </article>
          <article class="rounded-2xl border border-zinc-100 bg-zinc-50/80 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-zinc-400">Skills</p>
            <p class="mt-2 font-serif text-2xl text-zinc-900">{skillCount}</p>
            <p class="mt-1 text-xs leading-6 text-zinc-500">正在持续使用和公开分享的能力拼图</p>
          </article>
          <article class="rounded-2xl border border-zinc-100 bg-zinc-50/80 px-4 py-3">
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-zinc-400">Projects</p>
            <p class="mt-2 font-serif text-2xl text-zinc-900">{projects.length}</p>
            <p class="mt-1 text-xs leading-6 text-zinc-500">和这个站点一起长期更新的公开主线</p>
          </article>
        </div>
      </div>

      <div class="mt-5 rounded-[2.2rem] border border-zinc-100 bg-white/80 p-6 shadow-[0_14px_40px_rgba(24,24,27,0.03)] sm:p-7">
        <div class="flex items-center gap-2 text-sm font-medium text-violet-600">
          <span>✦</span>
          <span>公开身份切面</span>
        </div>
        <ul class="mt-5 space-y-4">
          <li class="flex gap-3 text-sm leading-7 text-zinc-600">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-violet-400"></span>
            <span>AI 工程方向的实践者，关注从模型理解到真实产品落地的完整链路。</span>
          </li>
          <li class="flex gap-3 text-sm leading-7 text-zinc-600">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-violet-400"></span>
            <span>把项目过程拆成知识分享，而不是只在最后摆一个成品截图。</span>
          </li>
          <li class="flex gap-3 text-sm leading-7 text-zinc-600">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-violet-400"></span>
            <span>也是二次元摄影师，希望把技术感和个人审美放进同一个长期作品里。</span>
          </li>
        </ul>
      </div>
    </aside>

    <div class="min-w-0 space-y-8 animate-fade-in-up motion-reduce:animate-none [animation-delay:120ms] lg:col-span-8 xl:col-span-9">
      <section class="overflow-hidden rounded-[2.7rem] border border-zinc-100 bg-white/95 p-8 shadow-[0_30px_80px_rgba(24,24,27,0.06)] sm:p-10 xl:p-12 2xl:p-14">
        <div class="grid gap-6 2xl:grid-cols-12 2xl:gap-8">
          <div class="2xl:col-span-8">
            <div class="inline-flex items-center gap-2 rounded-full border border-violet-100 bg-violet-50/70 px-4 py-2 text-sm font-medium text-violet-700">
              <span>✦</span>
              <span>持续更新中的个人坐标</span>
            </div>

            <h2 class="mt-6 max-w-[14ch] font-serif text-5xl leading-[1.05] tracking-tight text-zinc-900 sm:text-6xl xl:text-7xl">
              把工程、分享和个人风格，放在同一个公开坐标系里。
            </h2>

            <p class="mt-6 max-w-4xl text-base leading-8 text-zinc-500 sm:text-lg 2xl:max-w-[52rem]">
              这个页面不是传统简历页，而是我怎么做项目、怎么整理内容、怎么理解长期表达的公开说明。你会在这里看到我的技术主线，也会看到这个网站为什么会长成知识分享站，而不是一张单薄的个人名片。
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-3 2xl:col-span-4 2xl:grid-cols-1 2xl:content-start">
            <article class="rounded-[1.8rem] border border-zinc-100 bg-zinc-50/80 p-5">
              <p class="text-sm font-medium text-violet-600">站点角色</p>
              <p class="mt-3 text-sm leading-7 text-zinc-600">
                作为公开工作台，承接文章、项目、复盘记录和内容分发的完整版沉淀。
              </p>
            </article>
            <article class="rounded-[1.8rem] border border-zinc-100 bg-zinc-50/80 p-5">
              <p class="text-sm font-medium text-violet-600">写作目标</p>
              <p class="mt-3 text-sm leading-7 text-zinc-600">
                尽量把每次实践写成可回看、可转发、可继续扩写的知识资产，而不是一次性动态。
              </p>
            </article>
            <article class="rounded-[1.8rem] border border-zinc-100 bg-zinc-50/80 p-5">
              <p class="text-sm font-medium text-violet-600">工作方式</p>
              <p class="mt-3 text-sm leading-7 text-zinc-600">
                用项目驱动学习，用分享倒逼总结，把技术和审美一起做成长期有辨识度的作品。
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="grid gap-8 2xl:grid-cols-12 2xl:gap-8">
        <article class="rounded-[2.3rem] border border-zinc-100 bg-white p-7 shadow-[0_18px_52px_rgba(24,24,27,0.04)] sm:p-8 2xl:col-span-7 2xl:p-9">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-violet-600">近期轨迹</p>
              <h2 class="mt-2 font-serif text-3xl tracking-tight text-zinc-900">从项目节点看自己的主线</h2>
            </div>
            <div class="rounded-full border border-zinc-200 bg-zinc-50 px-4 py-2 text-xs font-medium uppercase tracking-[0.24em] text-zinc-400">
              {timeline.length} entries
            </div>
          </div>

          <div class="mt-6 space-y-5">
            {timeline.map((item) => (
              <div class="relative rounded-[1.7rem] border border-zinc-100 bg-zinc-50/75 p-5 pl-6">
                <span class="absolute left-0 top-0 h-full w-px bg-gradient-to-b from-violet-300 via-violet-200 to-transparent"></span>
                <p class="text-xs font-medium uppercase tracking-[0.24em] text-zinc-400">{item.period}</p>
                <h3 class="mt-2 font-serif text-2xl tracking-tight text-zinc-900">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-zinc-500">{item.description}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="rounded-[2.3rem] border border-zinc-100 bg-white p-7 shadow-[0_18px_52px_rgba(24,24,27,0.04)] sm:p-8 2xl:col-span-5 2xl:p-9">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-violet-600">技能地图</p>
              <h2 class="mt-2 font-serif text-3xl tracking-tight text-zinc-900">现在稳定输出的能力组合</h2>
            </div>
            <div class="rounded-full border border-zinc-200 bg-zinc-50 px-4 py-2 text-xs font-medium uppercase tracking-[0.24em] text-zinc-400">
              {skillCount} tags
            </div>
          </div>

          <div class="mt-6 space-y-6">
            {skillGroups.map((group) => (
              <section class="rounded-[1.7rem] border border-zinc-100 bg-zinc-50/75 p-5">
                <h3 class="font-serif text-2xl tracking-tight text-zinc-900">{group.title}</h3>
                <div class="mt-4 flex flex-wrap gap-2.5">
                  {group.items.map((item) => (
                    <span class="rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600">
                      {item}
                    </span>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </article>
      </section>
    </div>
  </div>
</BaseLayout>
