---
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects, sitePrinciples } from "../data/site";
---

<BaseLayout title="Projects | muxin.space" description="正在推进和观察中的个人项目。">
  <section class="mx-auto max-w-4xl animate-fade-in-up motion-reduce:animate-none">
    <div class="rounded-[2rem] border border-zinc-100 bg-white p-7 shadow-[0_1px_0_rgba(24,24,27,0.02)] sm:p-10">
      <p class="text-sm font-medium text-violet-600">Projects</p>
      <h1 class="mt-3 font-serif text-4xl tracking-tight text-zinc-900 sm:text-5xl">
        把想法做成能跑、能看、能复盘的作品。
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-8 text-zinc-500">
        这里记录我正在推进的项目，以及它们分别解决什么问题、用了什么技术、接下来还要补什么。
      </p>
    </div>
  </section>

  <section class="mx-auto mt-10 grid max-w-4xl animate-fade-in-up motion-reduce:animate-none [animation-delay:120ms] gap-4 md:grid-cols-2">
    {projects.map((project) => <ProjectCard project={project} />)}
  </section>

  <section class="mx-auto mt-10 grid max-w-4xl animate-fade-in-up motion-reduce:animate-none [animation-delay:180ms] gap-4 md:grid-cols-3">
    {sitePrinciples.map((item) => (
      <article class="rounded-[1.75rem] border border-zinc-100 bg-zinc-50/70 p-5">
        <h3 class="font-serif text-xl tracking-tight text-zinc-900">{item.title}</h3>
        <p class="mt-3 text-sm leading-7 text-zinc-500">{item.description}</p>
      </article>
    ))}
  </section>
</BaseLayout>
