---
import { getCollection } from "astro:content";
import NoteCard from "../components/NoteCard.astro";
import ProfileAvatar from "../components/ProfileAvatar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  animeRecommendations,
  currentFocus,
  profile,
  projects,
  sitePrinciples,
} from "../data";

const notes = (await getCollection("notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="muxin.space | 知识分享与项目公开记录"
  description="分享 AI 工程、全栈实践、项目复盘和带点个人风格的长期内容。"
>
  <section class="mx-auto max-w-4xl animate-fade-in-up motion-reduce:animate-none">
    <div class="flex flex-col items-center gap-8 text-center lg:flex-row lg:items-center lg:text-left">
      <ProfileAvatar
        src={profile.avatar}
        alt={`${profile.name} 的头像`}
        sizeClass="h-32 w-32 sm:h-36 sm:w-36"
        badge="摄影在线"
      />

      <div class="min-w-0 flex-1">
        <div class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-700 shadow-sm">
          <span class="text-violet-500">✦</span>
          <span>{profile.badge}</span>
        </div>

        <h1 class="mt-6 max-w-3xl font-serif text-5xl leading-tight tracking-tight text-zinc-900 sm:text-6xl">
          Hi，我是 Muxin。
          <span class="block text-violet-600">把 AI 工程、产品实现和个人表达，做成公开分享。</span>
        </h1>

        <p class="mt-5 max-w-2xl text-base leading-8 text-zinc-500 sm:text-lg">
          {profile.description}
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-3 lg:justify-start">
          <a
            href="/notes/"
            class="inline-flex items-center rounded-full bg-zinc-900 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-zinc-200 transition duration-200 hover:-translate-y-0.5 hover:bg-violet-600"
          >
            阅读分享
            <span class="ml-2">→</span>
          </a>
          <a
            href="/about/"
            class="inline-flex items-center rounded-full border border-zinc-200 bg-white px-6 py-3 text-sm font-medium text-zinc-700 transition duration-200 hover:-translate-y-0.5 hover:border-violet-200 hover:text-violet-600"
          >
            关于我
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto mt-16 max-w-4xl animate-fade-in-up motion-reduce:animate-none [animation-delay:120ms] rounded-[2rem] border border-zinc-100 bg-gradient-to-br from-white via-white to-violet-50/50 p-6 shadow-[0_18px_50px_rgba(24,24,27,0.04)] sm:p-8">
    <div class="flex items-center gap-2 text-sm font-medium text-violet-600">
      <span>✿</span>
      <span>最近在看 / 推荐</span>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
      {animeRecommendations.map((item) => (
        <article class="rounded-2xl border border-zinc-100 bg-white p-4 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md">
          <h3 class="font-serif text-lg tracking-tight text-zinc-900">{item.title}</h3>
          <p class="mt-1 text-xs font-medium text-violet-600">{item.category}</p>
          <p class="mt-2 text-sm leading-6 text-zinc-500">{item.note}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto mt-20 grid max-w-4xl animate-fade-in-up motion-reduce:animate-none [animation-delay:180ms] gap-8 lg:grid-cols-2">
    <article class="rounded-[2rem] border border-zinc-100 bg-white p-7 shadow-[0_1px_0_rgba(24,24,27,0.02)]">
      <div class="flex items-center gap-2 text-sm font-medium text-violet-600">
        <span>✦</span>
        <span>当前关注点</span>
      </div>

      <ul class="mt-5 space-y-4">
        {currentFocus.map((item) => (
          <li class="flex gap-3 text-sm leading-7 text-zinc-600">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-violet-400"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      <div class="mt-6 flex flex-wrap gap-2">
        {sitePrinciples.map((item) => (
          <span class="rounded-full border border-zinc-200 bg-zinc-50 px-3 py-1 text-xs text-zinc-600">
            {item.title}
          </span>
        ))}
      </div>
    </article>

    <article class="rounded-[2rem] border border-zinc-100 bg-white p-7 shadow-[0_1px_0_rgba(24,24,27,0.02)]">
      <div class="flex items-center gap-2 text-sm font-medium text-violet-600">
        <span>✦</span>
        <span>公开项目</span>
      </div>
      <div class="mt-5 space-y-4">
        {projects.slice(0, 2).map((project) => (
          <div class="rounded-2xl border border-zinc-100 bg-zinc-50/80 p-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-serif text-xl tracking-tight text-zinc-900">{project.name}</h3>
                <p class="mt-2 text-sm leading-6 text-zinc-500">{project.summary}</p>
              </div>
              <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-violet-600">
                {project.status}
              </span>
            </div>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="mt-20 animate-fade-in-up motion-reduce:animate-none [animation-delay:240ms]">
    <div class="mx-auto flex max-w-4xl items-end justify-between gap-4">
      <div>
        <p class="text-sm font-medium text-violet-600">最新分享</p>
        <h2 class="mt-2 font-serif text-3xl tracking-tight text-zinc-900">把经验、踩坑和方法论整理成可检索内容</h2>
      </div>
      <a href="/notes/" class="text-sm font-medium text-zinc-500 transition hover:text-violet-600">
        查看全部 →
      </a>
    </div>

    <div class="mx-auto mt-8 max-w-4xl space-y-4">
      {notes.map((note) => <NoteCard note={note} />)}
    </div>
  </section>
</BaseLayout>
