---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => !data.draft);
  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateText = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(entry.data.pubDate);
---

<BaseLayout title={`${entry.data.title} | muxin.space`} description={entry.data.description}>
  <article class="mx-auto max-w-3xl rounded-[2rem] border border-zinc-100 bg-white p-6 shadow-[0_1px_0_rgba(24,24,27,0.02)] sm:p-10">
    <a
      href="/notes/"
      class="inline-flex items-center rounded-full border border-zinc-200 bg-zinc-50 px-4 py-2 text-sm font-medium text-zinc-600 transition hover:border-violet-200 hover:text-violet-600"
    >
      ← 返回笔记
    </a>

    <p class="mt-8 text-sm font-medium text-violet-600">Note</p>
    <h1 class="mt-3 font-serif text-4xl tracking-tight text-zinc-900 sm:text-5xl">
      {entry.data.title}
    </h1>
    <p class="mt-5 text-base leading-8 text-zinc-500">
      {entry.data.description}
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-zinc-400">
      <time datetime={entry.data.pubDate.toISOString()}>{dateText}</time>
      <span>·</span>
      <span>{entry.data.tags.join(" · ")}</span>
    </div>

    <div class="prose prose-zinc mt-10 max-w-none prose-headings:font-serif prose-headings:tracking-tight prose-a:text-violet-600 prose-a:no-underline hover:prose-a:text-violet-700 prose-strong:text-zinc-900 prose-code:rounded-md prose-code:bg-violet-50 prose-code:px-1 prose-code:py-0.5 prose-code:font-normal prose-pre:rounded-2xl prose-pre:bg-zinc-950 prose-pre:text-zinc-100">
      <Content />
    </div>
  </article>
</BaseLayout>
