---
import { getCollection } from "astro:content";
import NoteCard from "../../components/NoteCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const notes = (await getCollection("notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Sharing | muxin.space" description="AI 工程、前端实践、项目拆解与工作流分享。">
  <div class="grid gap-8 lg:grid-cols-12 lg:gap-10 xl:gap-14 2xl:gap-16">
    <section class="animate-fade-in-up motion-reduce:animate-none lg:col-span-4 xl:col-span-3 lg:sticky lg:top-24 lg:self-start">
      <div class="rounded-[2.3rem] border border-zinc-100 bg-white p-7 shadow-[0_12px_36px_rgba(24,24,27,0.04)] sm:p-8">
        <p class="text-sm font-medium text-violet-600">Sharing</p>
        <h1 class="mt-3 font-serif text-4xl leading-tight tracking-tight text-zinc-900 sm:text-5xl lg:text-4xl xl:text-5xl">
          这里放的是我愿意公开讲清楚的内容。
        </h1>
        <p class="mt-5 text-base leading-8 text-zinc-500">
          包括技术分享、项目复盘、工具实践和一些值得沉淀的思考。它们按时间归档，但目标不是堆数量，而是尽量做到可复现、可回看、可继续分发。
        </p>
        <div class="mt-6 inline-flex rounded-full border border-violet-200 bg-violet-50 px-4 py-2 text-sm font-medium text-violet-600">
          共 {notes.length} 篇公开分享
        </div>
      </div>
    </section>

    <section class="animate-fade-in-up motion-reduce:animate-none [animation-delay:120ms] space-y-4 lg:col-span-8 xl:col-span-9 2xl:space-y-5">
      {notes.map((note) => <NoteCard note={note} />)}
    </section>
  </div>
</BaseLayout>
