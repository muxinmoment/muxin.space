---
import { getCollection } from "astro:content";
import NoteCard from "../../components/NoteCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const notes = (await getCollection("notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Notes | muxin.space" description="学习笔记、技术复盘和项目过程记录。">
  <section class="mx-auto max-w-4xl animate-fade-in-up motion-reduce:animate-none">
    <div class="rounded-[2rem] border border-zinc-100 bg-white p-7 shadow-[0_1px_0_rgba(24,24,27,0.02)] sm:p-10">
      <p class="text-sm font-medium text-violet-600">Notes</p>
      <h1 class="mt-3 max-w-2xl font-serif text-4xl tracking-tight text-zinc-900 sm:text-5xl">
        学习、踩坑和复盘都写在这里。
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-8 text-zinc-500">
        文章按时间归档。这里不追求篇幅，而是追求可复现、可回看、可迭代。
      </p>
      <div class="mt-6 inline-flex rounded-full border border-violet-200 bg-violet-50 px-4 py-2 text-sm font-medium text-violet-600">
        共 {notes.length} 篇笔记
      </div>
    </div>
  </section>

  <section class="mx-auto mt-10 max-w-4xl animate-fade-in-up motion-reduce:animate-none [animation-delay:120ms] space-y-4">
    {notes.map((note) => <NoteCard note={note} />)}
  </section>
</BaseLayout>
