---
import { getCollection } from "astro:content";
import NoteCard from "../../../components/NoteCard.astro";
import { getNoteCategoryBySlug, noteCategoryLabels, noteCategoryMeta } from "../../../data";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  return noteCategoryLabels.map((category) => ({
    params: { slug: noteCategoryMeta[category].slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const meta = noteCategoryMeta[category];
const notes = (await getCollection("notes", ({ data }) => !data.draft && data.category === category))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const currentCategory = getNoteCategoryBySlug(meta.slug);
---

<BaseLayout
  title={`${category} | muxin.space`}
  description={meta.description}
>
  <div class="grid gap-8 lg:grid-cols-12 lg:gap-10 xl:gap-14 2xl:gap-16">
    <section class="animate-fade-in-up motion-reduce:animate-none lg:col-span-4 xl:col-span-3 lg:sticky lg:top-24 lg:self-start">
      <div class="rounded-[2.3rem] border border-zinc-100 bg-white p-7 shadow-[0_12px_36px_rgba(24,24,27,0.04)] sm:p-8">
        <a
          href="/notes/"
          class="inline-flex items-center rounded-full border border-zinc-200 bg-zinc-50 px-4 py-2 text-sm font-medium text-zinc-600 transition hover:border-violet-200 hover:text-violet-600"
        >
          ← 返回全部分享
        </a>

        <p class="mt-8 text-sm font-medium text-violet-600">Category</p>
        <h1 class="mt-3 font-serif text-4xl leading-tight tracking-tight text-zinc-900 sm:text-5xl lg:text-4xl xl:text-5xl">
          {category}
        </h1>
        <p class="mt-5 text-base leading-8 text-zinc-500">
          {meta.description}
        </p>

        <div class="mt-6 inline-flex rounded-full border border-violet-200 bg-violet-50 px-4 py-2 text-sm font-medium text-violet-600">
          共 {notes.length} 篇
        </div>

        <div class="mt-6 space-y-3 border-t border-zinc-100 pt-6">
          <p class="text-xs font-medium uppercase tracking-[0.24em] text-zinc-400">Browse</p>
          <div class="flex flex-wrap gap-2">
            <a
              href="/notes/"
              class="rounded-full border border-zinc-200 bg-zinc-50 px-3 py-1 text-xs font-medium text-zinc-600 transition hover:border-violet-200 hover:text-violet-600"
            >
              全部分享
            </a>
            {noteCategoryLabels.map((label) => (
              <a
                href={`/notes/category/${noteCategoryMeta[label].slug}/`}
                class:list={[
                  "rounded-full border px-3 py-1 text-xs font-medium transition",
                  label === currentCategory
                    ? "border-violet-200 bg-violet-50 text-violet-700"
                    : "border-zinc-200 bg-zinc-50 text-zinc-600 hover:border-violet-200 hover:text-violet-600",
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="animate-fade-in-up motion-reduce:animate-none [animation-delay:120ms] space-y-4 lg:col-span-8 xl:col-span-9 2xl:space-y-5">
      {notes.map((note) => <NoteCard note={note} />)}
    </section>
  </div>
</BaseLayout>
