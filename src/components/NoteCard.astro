---
import type { CollectionEntry } from "astro:content";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const dateText = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(note.data.pubDate);
---

<article class="group rounded-3xl border border-zinc-100 bg-white p-5 shadow-[0_1px_0_rgba(24,24,27,0.02)] transition duration-200 hover:-translate-y-0.5 hover:border-violet-200 hover:shadow-lg hover:shadow-violet-100/40">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-8">
    <time class="min-w-24 pt-1 text-sm text-zinc-400" datetime={note.data.pubDate.toISOString()}>
      {dateText}
    </time>

    <div class="min-w-0 flex-1">
      <a
        href={`/notes/${note.id}/`}
        class="font-serif text-xl tracking-tight text-zinc-900 transition-colors hover:text-violet-600"
      >
        {note.data.title}
      </a>

      <p class="mt-2 max-w-2xl text-sm leading-7 text-zinc-500">
        {note.data.description}
      </p>

      <div class="mt-4 flex flex-wrap gap-2">
        {note.data.tags.map((tag) => (
          <span class="rounded-full bg-violet-50 px-3 py-1 text-xs font-medium text-violet-600">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</article>
