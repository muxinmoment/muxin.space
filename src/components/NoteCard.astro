---
import type { CollectionEntry } from "astro:content";
import { noteCategoryMeta } from "../data";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const dateText = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(note.data.pubDate);
const categoryMeta = noteCategoryMeta[note.data.category];
---

<article class="group rounded-[2rem] border border-zinc-100 bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,rgba(250,250,255,0.92)_100%)] p-5 shadow-[0_12px_36px_rgba(24,24,27,0.04)] transition duration-300 hover:-translate-y-1 hover:border-violet-200 hover:shadow-[0_20px_44px_rgba(139,92,246,0.10)] sm:p-6">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:gap-8">
    <time class="min-w-24 pt-1 text-sm text-zinc-400" datetime={note.data.pubDate.toISOString()}>
      {dateText}
    </time>

    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-2">
        <a
          href={`/notes/category/${categoryMeta.slug}/`}
          class="rounded-full border border-violet-100 bg-violet-50 px-3 py-1 text-xs font-medium text-violet-700 transition hover:border-violet-200 hover:bg-white"
        >
          {note.data.category}
        </a>
      </div>

      <a
        href={`/notes/${note.id}/`}
        class="mt-3 block font-serif text-xl tracking-tight text-zinc-900 transition-colors hover:text-violet-600"
      >
        {note.data.title}
      </a>

      <p class="mt-2 max-w-2xl text-sm leading-7 text-zinc-500">
        {note.data.description}
      </p>

      <div class="mt-4 flex flex-wrap gap-2">
        {note.data.tags.map((tag) => (
          <span class="rounded-full bg-violet-50 px-3 py-1 text-xs font-medium text-violet-600">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</article>
