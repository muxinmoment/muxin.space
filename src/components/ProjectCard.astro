---
import type { Project } from "../data/site";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="rounded-[2rem] border border-zinc-100 bg-gradient-to-br from-white via-white to-violet-50/50 p-6 shadow-[0_1px_0_rgba(24,24,27,0.02)] transition duration-200 hover:-translate-y-1 hover:border-violet-200 hover:shadow-lg hover:shadow-violet-100/50">
  <div class="inline-flex rounded-full bg-violet-50 px-3 py-1 text-xs font-medium text-violet-600">
    {project.status}
  </div>

  <h3 class="mt-4 font-serif text-2xl tracking-tight text-zinc-900">{project.name}</h3>
  <p class="mt-3 text-sm leading-7 text-zinc-500">{project.summary}</p>

  <div class="mt-5 flex flex-wrap gap-2">
    {project.stack.map((item) => (
      <span class="rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs text-zinc-600">
        {item}
      </span>
    ))}
  </div>

  <div class="mt-3 flex flex-wrap gap-2">
    {project.highlights.map((item) => (
      <span class="rounded-full bg-violet-100 px-3 py-1 text-xs font-medium text-violet-700">
        {item}
      </span>
    ))}
  </div>
</article>
